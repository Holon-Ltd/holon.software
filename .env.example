# Bun contact API
HOST=0.0.0.0
PORT=3002

# Public URL used by the Astro form.
# In production, prefer /api/contact behind the same domain/reverse proxy.
PUBLIC_CONTACT_API_URL=http://localhost:3002/api/contact

# Postmark
POSTMARK_API_KEY=
CONTACT_FROM_EMAIL=apostol@holon.software
CONTACT_TO_EMAIL=apostol@holon.software

# Optional: lock down browser-origin form submissions.
# ALLOWED_ORIGIN=https://holon.software
