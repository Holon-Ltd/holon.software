---
import "../styles/global.css";

const siteName = "Holon Software";
const title = "Holon Software | Software systems for the age of AI";
const description =
  "Holon Software builds dependable software systems for the age of AI, with a focus on robust architecture, integration, and long-term maintainability.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const contactEndpoint =
  import.meta.env.PUBLIC_CONTACT_API_URL ||
  (import.meta.env.DEV ? "http://localhost:3002/api/contact" : "/api/contact");
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: Astro.site?.toString(),
  description,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1e2438" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body class="atmo-warm">
    <!-- Atmospheric glow layer -->
    <div class="pointer-events-none fixed inset-0" style="background:var(--glow)"></div>

    <main class="relative isolate overflow-hidden">
      <section class="mx-auto flex min-h-screen w-full max-w-5xl items-center px-5 py-10 sm:px-8 sm:py-12 lg:px-12">
        <div class="w-full p-2 sm:p-8 lg:p-12">
          <div class="max-w-3xl">
            <div class="relative inline-block max-w-full">
              <p class="max-w-full font-[DM_Serif_Display] text-[clamp(2.35rem,11vw,7rem)] font-normal leading-[0.92] tracking-[-0.03em] [overflow-wrap:anywhere]" style="color:var(--text-primary)">
                holon.<wbr /><span style="white-space:nowrap">software<button
                  id="holon-definition-trigger"
                  type="button"
                  class="ml-1 inline-flex translate-y-[-0.08em] items-start justify-center align-top text-[clamp(1.4rem,2vw,1.9rem)] font-normal leading-none transition focus:outline-none"
                  style="color:var(--accent)"
                  aria-label="What does Holon mean?"
                  aria-expanded="false"
                  aria-controls="holon-definition-popup"
                >
                  *
                </button></span>
              </p>
              <div
                id="holon-definition-popup"
                class="pointer-events-none fixed inset-x-4 top-20 z-10 hidden rounded-2xl p-5 shadow-xl shadow-black/20 sm:absolute sm:inset-x-auto sm:top-full sm:mt-4 sm:w-full sm:max-w-md"
                style="border:1px solid var(--surface-border);background:var(--bg-secondary)"
                role="dialog"
                aria-modal="false"
                aria-labelledby="holon-definition-title"
              >
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p
                      id="holon-definition-title"
                      class="text-[0.7rem] font-semibold uppercase tracking-[0.14em] sm:tracking-[0.16em]"
                      style="color:var(--accent)"
                    >
                      Why Holon
                    </p>
                    <p class="mt-3 text-base leading-7" style="color:var(--text-secondary)">
                      A holon is something that is both a whole in itself and part of a
                      larger whole. The word combines the Greek <em>holos</em>, meaning
                      "whole," with the suffix <em>-on</em>, suggesting a part or
                      particle. It was introduced by Arthur Koestler in 1967 in
                      <em>The Ghost in the Machine</em>.
                    </p>
                  </div>
                  <button
                    id="holon-definition-close"
                    type="button"
                    class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-sm leading-none transition hover:bg-white/10 focus:outline-none sm:h-8 sm:w-8 sm:text-base"
                    style="border:1px solid var(--surface-border);background:var(--surface);color:var(--text-secondary)"
                    aria-label="Close definition popup"
                  >
                    ×
                  </button>
                </div>
              </div>
            </div>
            <h1 class="mt-5 font-[DM_Serif_Display] text-[clamp(1.25rem,2vw,1.9rem)] font-normal italic leading-[1.2] tracking-[-0.02em]" style="color:var(--accent-light)">
              Software systems for the age of AI
            </h1>
            <p class="mt-6 max-w-2xl text-[clamp(1.05rem,1.6vw,1.3rem)] leading-8" style="color:var(--text-secondary)">
              We design and build cutting edge software systems for AI-native products,
              combining strong architecture, thoughtful integration, and an emphasis on
              clarity that lasts.
            </p>

            <div class="mt-10 flex max-w-2xl flex-col gap-4">
              <div class="flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
                <button
                  id="contact-modal-trigger"
                  type="button"
                  class="inline-flex w-full items-center justify-center rounded-full px-6 py-3 text-sm font-semibold tracking-[0.12em] text-white transition hover:brightness-110 sm:w-auto"
                  style="background:var(--accent-strong)"
                >
                  Contact
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <div
      id="contact-modal"
      class="fixed inset-0 z-20 hidden items-end justify-center overflow-y-auto bg-black/50 p-3 backdrop-blur-sm sm:items-center sm:p-4"
      role="dialog"
      aria-modal="true"
      aria-label="Contact form"
    >
      <div class="relative max-h-[calc(100dvh-1.5rem)] w-full max-w-2xl overflow-y-auto rounded-[1.75rem] px-5 pb-5 pt-5 shadow-2xl shadow-black/30 sm:max-h-[calc(100dvh-2rem)] sm:rounded-[2rem] sm:px-8 sm:pb-8 sm:pt-8" style="border:1px solid var(--surface-border);background:var(--bg-secondary)">
        <button
          id="contact-modal-close"
          type="button"
          class="absolute right-4 top-4 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-base leading-none transition hover:bg-white/10 focus:outline-none sm:right-5 sm:top-5 sm:h-9 sm:w-9 sm:text-lg"
          style="border:1px solid var(--surface-border);background:var(--surface);color:var(--text-secondary)"
          aria-label="Close contact form"
        >
          ×
        </button>

        <form
          id="contact-form"
          data-endpoint={contactEndpoint}
          class="space-y-4 pt-2 sm:pt-5"
        >
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="mb-2 block text-sm font-medium tracking-[0.06em]" style="color:var(--text-secondary)">
                Name
              </span>
              <input
                id="contact-name"
                name="name"
                autocomplete="name"
                required
                class="w-full rounded-2xl bg-white/5 px-4 py-3 text-base outline-none transition focus:bg-white/8"
                style="border:1px solid var(--surface-border);color:var(--text-primary)"
                placeholder="Your name"
              />
            </label>
            <label class="block">
              <span class="mb-2 block text-sm font-medium tracking-[0.06em]" style="color:var(--text-secondary)">
                Email
              </span>
              <input
                type="email"
                name="email"
                autocomplete="email"
                required
                class="w-full rounded-2xl bg-white/5 px-4 py-3 text-base outline-none transition focus:bg-white/8"
                style="border:1px solid var(--surface-border);color:var(--text-primary)"
                placeholder="you@company.com"
              />
            </label>
          </div>
          <label class="block">
              <span class="mb-2 block text-sm font-medium tracking-[0.06em]" style="color:var(--text-secondary)">
              Message
            </span>
            <textarea
              name="message"
              rows="5"
              required
              class="w-full rounded-3xl bg-white/5 px-4 py-3 text-base outline-none transition focus:bg-white/8"
              style="border:1px solid var(--surface-border);color:var(--text-primary)"
              placeholder="Tell me a bit about what you are building and what kind of help you need."
            ></textarea>
          </label>
          <div class="absolute left-[-9999px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
            <label>
              Website
              <input name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>
          <div class="w-full space-y-3">
            <div class="flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
              <button
                id="contact-submit"
                type="submit"
                class="inline-flex w-full items-center justify-center rounded-full px-6 py-3 text-sm font-semibold tracking-[0.12em] text-white transition hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-70 sm:w-auto"
                style="background:var(--accent-strong)"
              >
                Send message
              </button>
            </div>
            <div
              id="contact-status"
              class="hidden w-full rounded-2xl border px-4 py-3 text-sm font-medium leading-6"
              aria-live="polite"
            ></div>
          </div>
        </form>
        <div
          id="contact-success"
          class="hidden w-full pt-2 sm:pt-5"
          aria-live="polite"
        >
          <div class="w-full rounded-3xl border border-emerald-400/20 bg-emerald-500/10 px-5 py-6 text-emerald-300 sm:px-6 sm:py-7">
            <p class="text-[1.25rem] font-semibold leading-7 tracking-[-0.02em] sm:text-[1.45rem]">
              Message sent successfully.
            </p>
            <p class="mt-3 text-base leading-7 text-emerald-300/70">
              Your message has been sent. A copy should arrive in your inbox shortly.
            </p>
          </div>
        </div>
      </div>
    </div>
    <script>
      const contactModal = document.getElementById("contact-modal");
      const contactModalTrigger = document.getElementById("contact-modal-trigger");
      const contactModalClose = document.getElementById("contact-modal-close");
      const contactForm = document.getElementById("contact-form");
      const contactNameInput = document.getElementById("contact-name");
      const contactSubmit = document.getElementById("contact-submit");
      const contactStatus = document.getElementById("contact-status");
      const contactSuccess = document.getElementById("contact-success");
      const holonDefinitionTrigger = document.getElementById("holon-definition-trigger");
      const holonDefinitionPopup = document.getElementById("holon-definition-popup");
      const holonDefinitionClose = document.getElementById("holon-definition-close");

      const setContactStatus = (message, state = "idle") => {
        if (!contactStatus) return;

        if (!message) {
          contactStatus.textContent = "";
          contactStatus.className =
            "hidden w-full rounded-2xl border px-4 py-3 text-sm font-medium leading-6";
          return;
        }

        const stateClasses = {
          sending:
            "block w-full rounded-2xl border border-[--accent-border] bg-[--accent-bg] px-4 py-3 text-sm font-medium leading-6 text-[--text-secondary]",
          success:
            "block w-full rounded-2xl border border-emerald-400/20 bg-emerald-500/10 px-4 py-3 text-base font-semibold leading-6 text-emerald-300",
          error:
            "block w-full rounded-2xl border border-rose-400/30 bg-rose-500/10 px-4 py-3 text-sm font-medium leading-6 text-rose-300",
        };

        contactStatus.textContent = message;
        contactStatus.className =
          stateClasses[state] ||
          "block w-full rounded-2xl border border-[--surface-border] bg-[--surface] px-4 py-3 text-sm font-medium leading-6 text-[--text-primary]";
      };

      const setContactModalOpen = (isOpen) => {
        if (!contactModal || !contactModalTrigger) return;

        contactModal.classList.toggle("hidden", !isOpen);
        contactModal.classList.toggle("flex", isOpen);
        contactModalTrigger.setAttribute("aria-expanded", String(isOpen));
        document.body.style.overflow = isOpen ? "hidden" : "";

        if (isOpen && contactNameInput instanceof HTMLInputElement) {
          contactForm?.classList.remove("hidden");
          contactSuccess?.classList.add("hidden");
          setContactStatus("", "idle");
          window.setTimeout(() => {
            contactNameInput.focus();
          }, 20);
        }

        if (!isOpen) {
          contactModalTrigger.focus();
        }
      };

      if (contactModal && contactModalTrigger) {
        contactModalTrigger.addEventListener("click", () => {
          setContactModalOpen(true);
        });

        contactModalClose?.addEventListener("click", () => {
          setContactModalOpen(false);
        });

        contactModal.addEventListener("click", (event) => {
          if (event.target === contactModal) {
            setContactModalOpen(false);
          }
        });
      }

      if (
        contactForm instanceof HTMLFormElement &&
        contactSubmit instanceof HTMLButtonElement &&
        contactStatus
      ) {
        const endpoint = contactForm.dataset.endpoint || "/api/contact";

        contactForm.addEventListener("submit", async (event) => {
          event.preventDefault();

          const formData = new FormData(contactForm);
          const payload = Object.fromEntries(formData.entries());

          contactSubmit.disabled = true;
          contactSubmit.textContent = "Sending...";
          setContactStatus("Sending your message...", "sending");

          try {
            const response = await fetch(endpoint, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(payload),
            });

            const data = await response.json().catch(() => ({}));

            if (!response.ok) {
              throw new Error(data.error || "Failed to send message");
            }

            contactForm.reset();
            setContactStatus("", "idle");
            contactForm.classList.add("hidden");
            contactSuccess?.classList.remove("hidden");
          } catch (error) {
            const message =
              error instanceof Error ? error.message : "Failed to send message";
            setContactStatus(message, "error");
          } finally {
            contactSubmit.disabled = false;
            contactSubmit.textContent = "Send message";
          }
        });
      }

      if (holonDefinitionTrigger && holonDefinitionPopup) {
        const setHolonDefinitionOpen = (isOpen) => {
          holonDefinitionPopup.classList.toggle("hidden", !isOpen);
          holonDefinitionPopup.classList.toggle("pointer-events-none", !isOpen);
          holonDefinitionTrigger.setAttribute("aria-expanded", String(isOpen));
        };

        const isHolonDefinitionOpen = () => !holonDefinitionPopup.classList.contains("hidden");

        holonDefinitionTrigger.addEventListener("click", (event) => {
          event.stopPropagation();
          setHolonDefinitionOpen(!isHolonDefinitionOpen());
        });

        holonDefinitionClose?.addEventListener("click", () => {
          setHolonDefinitionOpen(false);
          holonDefinitionTrigger.focus();
        });

        document.addEventListener("click", (event) => {
          if (!(event.target instanceof Node)) return;
          if (
            holonDefinitionPopup.contains(event.target) ||
            holonDefinitionTrigger.contains(event.target)
          ) {
            return;
          }

          setHolonDefinitionOpen(false);
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            setHolonDefinitionOpen(false);
            setContactModalOpen(false);
          }
        });
      }
    </script>
  </body>
</html>
