---
import "../styles/global.css";

const siteName = "Holon Software";
const title = "Holon Software | Software systems for the age of AI";
const description =
  "Holon Software builds dependable software systems for the age of AI, with a focus on robust architecture, integration, and long-term maintainability.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_API_URL || "/api/contact";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: Astro.site?.toString(),
  description,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#06162f" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="relative isolate overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute inset-x-0 top-[-12rem] h-[28rem] bg-[radial-gradient(circle,rgba(125,211,252,0.18),transparent_58%)]"></div>
        <div class="absolute right-[-8rem] top-[10rem] h-[22rem] w-[22rem] rounded-full bg-sky-400/10 blur-3xl"></div>
        <div class="absolute bottom-[-6rem] left-[-4rem] h-[20rem] w-[20rem] rounded-full bg-blue-500/10 blur-3xl"></div>
      </div>

      <section class="mx-auto flex min-h-screen w-full max-w-6xl items-center px-5 py-10 sm:px-8 sm:py-12 lg:px-12">
        <div class="w-full rounded-[1.75rem] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20 backdrop-blur sm:rounded-[2rem] sm:p-12 lg:p-16">
          <div class="max-w-4xl">
            <div class="relative inline-block max-w-full">
              <p class="max-w-full text-[clamp(2.35rem,13vw,7rem)] font-semibold leading-[0.92] tracking-[-0.06em] text-white [overflow-wrap:anywhere]">
                holon.<wbr />software<button
                  id="holon-definition-trigger"
                  type="button"
                  class="ml-1 inline-flex translate-y-[-0.08em] items-start justify-center align-top text-[clamp(1.4rem,2vw,1.9rem)] font-semibold leading-none text-sky-100/82 transition hover:text-sky-50 focus:outline-none"
                  aria-label="What does Holon mean?"
                  aria-expanded="false"
                  aria-controls="holon-definition-popup"
                >
                  *
                </button>
              </p>
              <div
                id="holon-definition-popup"
                class="pointer-events-none fixed inset-x-4 top-20 z-10 hidden rounded-3xl border border-white/12 bg-slate-950/92 p-5 shadow-2xl shadow-black/35 backdrop-blur sm:absolute sm:inset-x-auto sm:top-full sm:mt-4 sm:w-full sm:max-w-md"
                role="dialog"
                aria-modal="false"
                aria-labelledby="holon-definition-title"
              >
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p
                      id="holon-definition-title"
                      class="font-semibold uppercase tracking-[0.14em] text-sky-200/82 sm:text-[0.8rem] sm:tracking-[0.16em]"
                    >
                      Why Holon
                    </p>
                    <p class="mt-3 text-base leading-7 text-slate-200/88">
                      A holon is something that is both a whole in itself and part of a
                      larger whole. The word combines the Greek <em>holos</em>, meaning
                      "whole," with the suffix <em>-on</em>, suggesting a part or
                      particle, and was introduced by Arthur Koestler in 1967 in
                      <em>The Ghost in the Machine</em>.
                    </p>
                  </div>
                  <button
                    id="holon-definition-close"
                    type="button"
                    class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-white/12 bg-white/5 text-sm leading-none text-slate-200 transition hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-sky-300/60 focus:ring-offset-2 focus:ring-offset-slate-950 sm:h-8 sm:w-8 sm:text-base"
                    aria-label="Close definition popup"
                  >
                    ×
                  </button>
                </div>
              </div>
            </div>
            <h1 class="mt-5 text-[clamp(1.25rem,2vw,1.9rem)] font-medium leading-[1.2] tracking-[-0.02em] text-sky-100/82">
              Software systems for the age of AI
            </h1>
            <p class="mt-6 max-w-2xl text-[clamp(1.05rem,1.6vw,1.3rem)] leading-8 text-slate-200/85">
              We design and build dependable software systems for AI-native products,
              combining strong architecture, thoughtful integration, and an emphasis on
              clarity that lasts.
            </p>

            <div class="mt-10 flex max-w-2xl flex-col gap-4">
              <div class="flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
                <button
                  id="contact-modal-trigger"
                  type="button"
                  class="inline-flex w-full items-center justify-center rounded-full bg-sky-300 px-6 py-3 text-sm font-semibold tracking-[0.12em] text-slate-950 transition hover:bg-sky-200 sm:w-auto"
                >
                  Contact
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <div
      id="contact-modal"
      class="fixed inset-0 z-20 hidden items-end justify-center overflow-y-auto bg-slate-950/72 p-3 backdrop-blur-sm sm:items-center sm:p-4"
      role="dialog"
      aria-modal="true"
      aria-label="Contact form"
    >
      <div class="relative max-h-[calc(100dvh-1.5rem)] w-full max-w-2xl overflow-y-auto rounded-[1.75rem] border border-white/10 bg-[#071327] px-5 pb-5 pt-5 shadow-2xl shadow-black/40 sm:max-h-[calc(100dvh-2rem)] sm:rounded-[2rem] sm:px-8 sm:pb-8 sm:pt-8">
        <button
          id="contact-modal-close"
          type="button"
          class="absolute right-4 top-4 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-white/12 bg-white/5 text-base leading-none text-slate-200 transition hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-sky-300/60 focus:ring-offset-2 focus:ring-offset-slate-950 sm:right-5 sm:top-5 sm:h-9 sm:w-9 sm:text-lg"
          aria-label="Close contact form"
        >
          ×
        </button>

        <form
          id="contact-form"
          data-endpoint={contactEndpoint}
          class="space-y-4 pt-2 sm:pt-5"
        >
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="mb-2 block text-sm font-medium tracking-[0.06em] text-slate-200/82">
                Name
              </span>
              <input
                id="contact-name"
                name="name"
                autocomplete="name"
                required
                class="w-full rounded-2xl border border-white/10 bg-white/6 px-4 py-3 text-base text-white outline-none transition placeholder:text-slate-400/70 focus:border-sky-300/60 focus:bg-white/8"
                placeholder="Your name"
              />
            </label>
            <label class="block">
              <span class="mb-2 block text-sm font-medium tracking-[0.06em] text-slate-200/82">
                Email
              </span>
              <input
                type="email"
                name="email"
                autocomplete="email"
                required
                class="w-full rounded-2xl border border-white/10 bg-white/6 px-4 py-3 text-base text-white outline-none transition placeholder:text-slate-400/70 focus:border-sky-300/60 focus:bg-white/8"
                placeholder="you@company.com"
              />
            </label>
          </div>
          <label class="block">
            <span class="mb-2 block text-sm font-medium tracking-[0.06em] text-slate-200/82">
              Message
            </span>
            <textarea
              name="message"
              rows="5"
              required
              class="w-full rounded-3xl border border-white/10 bg-white/6 px-4 py-3 text-base text-white outline-none transition placeholder:text-slate-400/70 focus:border-sky-300/60 focus:bg-white/8"
              placeholder="Tell me a bit about what you are building and what kind of help you need."
            ></textarea>
          </label>
          <div class="absolute left-[-9999px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
            <label>
              Website
              <input name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>
          <div class="flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
            <button
              id="contact-submit"
              type="submit"
              class="inline-flex w-full items-center justify-center rounded-full bg-sky-300 px-6 py-3 text-sm font-semibold tracking-[0.12em] text-slate-950 transition hover:bg-sky-200 disabled:cursor-not-allowed disabled:opacity-70 sm:w-auto"
            >
              Send message
            </button>
            <span
              id="contact-status"
              class="text-sm leading-6 text-slate-300/78"
              aria-live="polite"
            ></span>
          </div>
        </form>
      </div>
    </div>
    <script>
      const contactModal = document.getElementById("contact-modal");
      const contactModalTrigger = document.getElementById("contact-modal-trigger");
      const contactModalClose = document.getElementById("contact-modal-close");
      const contactForm = document.getElementById("contact-form");
      const contactNameInput = document.getElementById("contact-name");
      const contactSubmit = document.getElementById("contact-submit");
      const contactStatus = document.getElementById("contact-status");
      const holonDefinitionTrigger = document.getElementById("holon-definition-trigger");
      const holonDefinitionPopup = document.getElementById("holon-definition-popup");
      const holonDefinitionClose = document.getElementById("holon-definition-close");

      const setContactModalOpen = (isOpen) => {
        if (!contactModal || !contactModalTrigger) return;

        contactModal.classList.toggle("hidden", !isOpen);
        contactModal.classList.toggle("flex", isOpen);
        contactModalTrigger.setAttribute("aria-expanded", String(isOpen));
        document.body.style.overflow = isOpen ? "hidden" : "";

        if (isOpen && contactNameInput instanceof HTMLInputElement) {
          window.setTimeout(() => {
            contactNameInput.focus();
          }, 20);
        }

        if (!isOpen) {
          contactModalTrigger.focus();
        }
      };

      if (contactModal && contactModalTrigger) {
        contactModalTrigger.addEventListener("click", () => {
          setContactModalOpen(true);
        });

        contactModalClose?.addEventListener("click", () => {
          setContactModalOpen(false);
        });

        contactModal.addEventListener("click", (event) => {
          if (event.target === contactModal) {
            setContactModalOpen(false);
          }
        });
      }

      if (
        contactForm instanceof HTMLFormElement &&
        contactSubmit instanceof HTMLButtonElement &&
        contactStatus
      ) {
        const endpoint = contactForm.dataset.endpoint || "/api/contact";

        contactForm.addEventListener("submit", async (event) => {
          event.preventDefault();

          const formData = new FormData(contactForm);
          const payload = Object.fromEntries(formData.entries());

          contactSubmit.disabled = true;
          contactSubmit.textContent = "Sending...";
          contactStatus.textContent = "Sending your message...";

          try {
            const response = await fetch(endpoint, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(payload),
            });

            const data = await response.json().catch(() => ({}));

            if (!response.ok) {
              throw new Error(data.error || "Failed to send message");
            }

            contactForm.reset();
            contactStatus.textContent = "Message sent. Check your inbox for a copy.";
            window.setTimeout(() => {
              setContactModalOpen(false);
            }, 900);
          } catch (error) {
            const message =
              error instanceof Error ? error.message : "Failed to send message";
            contactStatus.textContent = message;
          } finally {
            contactSubmit.disabled = false;
            contactSubmit.textContent = "Send message";
          }
        });
      }

      if (holonDefinitionTrigger && holonDefinitionPopup) {
        const setHolonDefinitionOpen = (isOpen) => {
          holonDefinitionPopup.classList.toggle("hidden", !isOpen);
          holonDefinitionPopup.classList.toggle("pointer-events-none", !isOpen);
          holonDefinitionTrigger.setAttribute("aria-expanded", String(isOpen));
        };

        const isHolonDefinitionOpen = () => !holonDefinitionPopup.classList.contains("hidden");

        holonDefinitionTrigger.addEventListener("click", (event) => {
          event.stopPropagation();
          setHolonDefinitionOpen(!isHolonDefinitionOpen());
        });

        holonDefinitionClose?.addEventListener("click", () => {
          setHolonDefinitionOpen(false);
          holonDefinitionTrigger.focus();
        });

        document.addEventListener("click", (event) => {
          if (!(event.target instanceof Node)) return;
          if (
            holonDefinitionPopup.contains(event.target) ||
            holonDefinitionTrigger.contains(event.target)
          ) {
            return;
          }

          setHolonDefinitionOpen(false);
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            setHolonDefinitionOpen(false);
            setContactModalOpen(false);
          }
        });
      }
    </script>
  </body>
</html>
